    "url": "https://github.com/corno/pareto-graphviz/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/corno/pareto-graphviz.git"
  },
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "module": "./dist/index.js",
  "bin": {},
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "documentation"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "liana-core": "^0.1.0",
    "pareto-fountain-pen": "^0.4.0",
