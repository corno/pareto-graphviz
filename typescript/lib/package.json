{
  "name": "pareto-graphviz",
  "version": "0.2.59",
  "author": "Corno",
  "license": "Apache-2.0",
  "description": "A library that provides a Liana-frontend for Graphviz, allowing you to generate Graphviz diagrams using Liana's syntax and features, both programmatically and manually in a Liana editing environment",
  "keywords": [
    "graphviz",
    "liana",
    "diagram",
    "API"
  ],
  "homepage": "https://github.com/corno/pareto-graphviz#readme",
  "bugs": {
    "url": "https://github.com/corno/pareto-graphviz/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/corno/pareto-graphviz.git"
  },
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "bin": {},
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "documentation"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "astn-core": "^0.5.0",
    "liana-core": "^0.1.0",
    "pareto-core": "^0.1.0",
    "pareto-core-shorthands": "^0.2.0",
    "pareto-fountain-pen": "^0.4.0",
    "pareto-static-html": "^0.1.0"
  }
}
